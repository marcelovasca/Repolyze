# ===========================================
# 🚀 REQUIRED CONFIGURATION
# ===========================================

# GitHub Personal Access Token (Analysis Engine)
# Required scopes: repo, read:user
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# DeepInfra Configuration (AI Engine)
# Get yours at: https://deepinfra.com/dash/api_keys
DEEPINFRA_API_KEY=your-deepinfra-api-key-here
# Optional: Defaults to meta-llama/Llama-3.3-70B-Instruct if not set
DEEPINFRA_MODEL_ID=meta-llama/Llama-3.3-70B-Instruct

# ─── Database (PostgreSQL) ─────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/repolyze

# ─── NextAuth (Security) ───────────────────────────
# Generate with: npx auth secret
AUTH_SECRET=your-auth-secret-here


# ===========================================
# 🔐 OPTIONAL: AUTHENTICATION (OAUTH)
# ===========================================
# Only needed if you want "Sign in with GitHub/Google" buttons to work.
# If left empty, the app will still analyze repos using the GITHUB_TOKEN above.

# GitHub OAuth (https://github.com/settings/developers)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Google OAuth (https://console.cloud.google.com/apis/credentials)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=


# ===========================================
# 📈 OPTIONAL: OTHER SERVICES
# ===========================================
NEXT_PUBLIC_SITE_URL=http://localhost:3010
NEXT_PUBLIC_UMAMI_WEBSITE_ID=

# Polar Access
POLAR_ACCESS_TOKEN=
NEXT_PUBLIC_POLAR_PRODUCT_ID=
POLAR_WEBHOOK_SECRET=

# ─── Promo Banner ──────────────────────────────────
NEXT_PUBLIC_PROMO_MESSAGE=Powered by Repolyze.
NEXT_PUBLIC_PROMO_LINK=https://github.com/marcelovasca/Repolyze
NEXT_PUBLIC_PROMO_ENABLED=false
